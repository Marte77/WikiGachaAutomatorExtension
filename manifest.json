{
  "manifest_version": 2,
  "name": "WikiGachaAuto",
  "version": "1.0",

  "description": "Automate WikiGachaAuto. Available on https://github.com/Marte77/WikiGachaAutomatorExtension ",

  "icons": {
    "48": "icons/border-48.png"
  },
"browser_specific_settings": {
  "gecko": {
    "id": "eu@martinho.pt"
  }
},
  "content_scripts": [
    {
      "matches": ["*://wikigacha.com/*"],
      "js": ["index.js"]
    }
  ]
}
